{
  "name": "mongo-unit-of-work",
  "version": "3.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Zaid Al-Omari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zaid-AlOmari/mongo-unit-of-work.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "clean": "rm -rf dist dist-test",
    "build": "rm -rf dist && ./node_modules/.bin/tsc --p tsconfig.json",
    "test": "rm -rf dist-test && cd test && ../node_modules/.bin/tsc -p . && NODE_ENV=test NODE_OPTIONS='--disable-warning=ExperimentalWarning' node --test --experimental-test-coverage --test-coverage-include='../dist-test/src/**/*.js' --test-coverage-exclude='../dist-test/test/**/*.js' --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 ../dist-test/test/index.spec.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/*/*.ts --format codeframe",
    "fix-lint": "eslint src/*/*.ts --fix"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-formatter-codeframe": "^7.32.2",
    "typescript": "^6.0.3"
  }
}
